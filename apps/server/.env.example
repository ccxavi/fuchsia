APP_NAME=fuchsia-api
ENV=dev
LOG_LEVEL=INFO

# Supabase project settings.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Legacy fallback if you are still using the old key format.
# SUPABASE_ANON_KEY=eyJ...
SUPABASE_AUDIENCE=authenticated

# Override these only if you do not want them derived from SUPABASE_URL.
# SUPABASE_ISSUER=https://your-project-ref.supabase.co/auth/v1
# SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# Supabase Postgres connection for SQLAlchemy and Alembic.
DATABASE_URL=postgresql+psycopg://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# DeepSeek chat completion API (OpenAI-compatible). Handles text-only requests.
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Gemini via its OpenAI-compatible endpoint. Handles requests containing images.
GEMINI_API_KEY=xxx
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.5-flash

# Tavily Search API for the stylist's web_search tool.
TAVILY_API_KEY=tvly-xxx
TAVILY_BASE_URL=https://api.tavily.com
